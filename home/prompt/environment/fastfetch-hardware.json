{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": "none",
  "modules": [
    "title",
    {
      "format": "Core Software",
      "outputColor": "#FF00FF",
      "type": "custom"
    },
    "os",
    "kernel",
    "bios",
    "bootmgr",
    "initsystem",
    "lm",
    "shell",
    "de",
    "wm",
    "terminal",
    "locale",
    {
      "format": "Core Hardware",
      "outputColor": "#FF00FF",
      "type": "custom"
    },
    "host",
    "board",
    "tpm",
    {
      "format": "Computing",
      "outputColor": "#FF00FF",
      "type": "custom"
    },
    "cpu",
    "gpu",
    "vulkan",
    "opengl",
    "opencl",
    {
      "type": "memory",
      "format": "{total}"
    },
    {
      "type": "swap",
      "format": "{total}"
    },
    {
      "type": "disk",
      "showSubvolumes": false
    },
    {
      "format": "Output",
      "outputColor": "#FF00FF",
      "type": "custom"
    },
    "display",
    "brightness",
    "font",
    "sound",
    {
      "format": "Input",
      "outputColor": "#FF00FF",
      "type": "custom"
    },
    "keyboard",
    "mouse",
    "camera",
    "gamepad"
  ]
}
